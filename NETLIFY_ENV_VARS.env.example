# ─────────────────────────────────────────────────────────────
#  NA²QUIZ — Variables d'environnement Netlify
#  À CONFIGURER dans : Netlify → Site Settings → Environment Variables
#  NE PAS committer ce fichier avec les vraies valeurs secrètes !
# ─────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════
#  OBLIGATOIRES — sans ces variables, l'API ne fonctionnera pas
# ══════════════════════════════════════════════════════════════

# MongoDB Atlas connection string
# Format : mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DBNAME
MONGODB_URI=mongodb+srv://na2quiz_user:VOTRE_MOT_DE_PASSE@na2quiz.xxxxx.mongodb.net/na2quiz?retryWrites=true&w=majority

# Clé secrète JWT (choisir une longue chaîne aléatoire)
JWT_SECRET=na2quiz_REMPLACER_PAR_UNE_CHAINE_ALEATOIRE_LONGUE_2024

# URL du frontend (pour CORS dans les functions)
FRONTEND_URL=https://VOTRE-SITE.netlify.app

# ══════════════════════════════════════════════════════════════
#  REACT (préfixe REACT_APP_ = injectées dans le build CRA)
# ══════════════════════════════════════════════════════════════

# URL du serveur Socket.IO (Railway/Render)
REACT_APP_SOCKET_URL=https://VOTRE-SOCKET.railway.app

# API REST — vide = même domaine Netlify (redirect netlify.toml)
# Ne pas mettre d'URL ici en production, laisser vide
REACT_APP_BACKEND_URL=

# Clé DeepSeek pour génération IA
REACT_APP_DEEPSEEK_API_KEY=sk-ec935c2782e74bbfbfae4be91863672c

# Firebase (si utilisé pour l'auth)
REACT_APP_FIREBASE_API_KEY=AIzaSyCfFdt9gkQHjqRxAhTBu0CTbDdBQ3jKtTE
REACT_APP_FIREBASE_AUTH_DOMAIN=na2quizapp-6b74a.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=na2quizapp-6b74a
REACT_APP_FIREBASE_STORAGE_BUCKET=na2quizapp-6b74a.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=110588338490
REACT_APP_FIREBASE_APP_ID=1:110588338490:web:3c5ea1e99dbe00e647b003

# ══════════════════════════════════════════════════════════════
#  BUILD NETLIFY — à définir aussi
# ══════════════════════════════════════════════════════════════

# Évite que les warnings React bloquent le build
CI=false

# Pas de source maps en prod (build plus léger + plus rapide)
GENERATE_SOURCEMAP=false

# Version Node
NODE_VERSION=18
